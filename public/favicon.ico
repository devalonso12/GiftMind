import type { MetadataRoute } from 'next'

export default function manifest(): MetadataRoute.Manifest {
  return {
    name: 'GiftMind',
    short_name: 'GiftMind',
    description: 'AI-Powered Web3 Gifting',
    start_url: '/',
    display: 'standalone',
    background_color: '#0a1628',
    theme_color: '#0d9488',
    icons: [
      {
        src: '/favicon.svg',
        sizes: 'any',
        type: 'image/svg+xml',
      },
    ],
  }
}
